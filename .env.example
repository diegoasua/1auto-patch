# Keep real secrets in .env. Do not commit them.

# Demo defaults:
PORT=3000
VAULT_PROVIDER=local
REPAIR_RUNTIME=local
HIBP_LIVE_CHECK=false

# 1Password real vault mode:
# 1. Install/sign in to `op`.
# 2. Either use desktop app integration, `op signin`, or set OP_SERVICE_ACCOUNT_TOKEN.
# 3. Flip VAULT_PROVIDER to 1password.
#
# VAULT_PROVIDER=1password
# OP_VAULT=Hackathon Demo
# OP_ITEM_LIMIT=25
# OP_PASSWORD_FIELD=password
# OP_SERVICE_ACCOUNT_TOKEN=ops_...

# Daytona sandbox mode:
# REPAIR_RUNTIME=daytona
# DAYTONA_API_KEY=...
# DAYTONA_TARGET=us
#
# Required only for the bundled local target because Daytona runs remotely.
# Use a tunnel such as `cloudflared tunnel --url http://localhost:3000`
# or `ngrok http 3000`, then paste the HTTPS origin here.
# DAYTONA_PUBLIC_BASE_URL=https://example.trycloudflare.com

# Real-site experimentation:
# Keep this off for the stable demo. When enabled, non-demo password sites
# become repairable through the generic Daytona browser heuristics.
# ENABLE_GENERIC_REPAIR=true
